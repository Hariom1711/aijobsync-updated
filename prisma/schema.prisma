generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String            @id @default(cuid())
  name            String?
  email           String            @unique
  password        String?
  image           String?
  emailVerified   DateTime?
  createdAt       DateTime          @default(now())
  profile         MasterProfile?
  resumes         Resume[]
  plan            SubscriptionPlan  @default(FREE)
  accounts        Account[]
  sessions        Session[]

  jobDescriptions  JobDescription[]
  profileMatches   ProfileMatch[]
  interviewSessions InterviewSession[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model MasterProfile {
  id            String   @id @default(cuid())
  userId        String   @unique

  fullName      String?
  phone         String?
  location      String?
  linkedin      String?
  github        String?
  portfolio     String?
  summary       String?  @db.Text

  education     Json?
  experience    Json?
  projects      Json?
  certifications Json?
  achievements  Json?

  coreSkills    Json?
  softSkills    String[]
  tools         String[]

  codingProfiles Json?
  languages     Json?

  completeness  Int?     @default(0)
  lastUpdated   DateTime @default(now()) @updatedAt
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JobDescription {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  jdText          String   @db.Text
  fileName        String?
  fileSize        Int?

  analysis        Json

  jobTitle        String?
  companyName     String?
  experienceLevel String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  matches         ProfileMatch[]
  resumes         Resume[]
  interviewSessions InterviewSession[]

  @@index([userId])
  @@index([jobTitle])
  @@index([createdAt])
}

model ProfileMatch {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  jdId            String
  jobDescription  JobDescription @relation(fields: [jdId], references: [id], onDelete: Cascade)

  profileId       String

  matchData       Json

  overallScore    Int
  potentialScore  Int?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  resumes         Resume[]

  @@index([userId])
  @@index([jdId])
  @@index([overallScore])
  @@index([createdAt])
}

model Resume {
  id              String     @id @default(cuid())
  userId          String
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  jdId            String?
  jobDescription  JobDescription? @relation(fields: [jdId], references: [id], onDelete: SetNull)

  matchId         String?
  profileMatch    ProfileMatch?   @relation(fields: [matchId], references: [id], onDelete: SetNull)

  jobDesc         String     @db.Text
  content         Json
  template        String

  score           Int?
  version         Int        @default(1)

  pdfUrl          String?
  docxUrl         String?

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  feedbacks       Feedback[]
  interviewSessions InterviewSession[]

  @@index([userId])
  @@index([jdId])
  @@index([matchId])
  @@index([createdAt])
}

model Feedback {
  id        String   @id @default(cuid())
  resumeId  String
  resume    Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  rating    Int?
  points    Json
  userNote  String?  @db.Text

  createdAt DateTime @default(now())

  @@index([resumeId])
}

// NEW: AI Interview sessions
model InterviewSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  resumeId  String
  resume    Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  jdId      String?
  jobDescription JobDescription? @relation(fields: [jdId], references: [id], onDelete: SetNull)

  // AI generated questions array
  questions Json     // Question[]

  // User answers array  { questionId, answer }[]
  answers   Json     @default("[]")

  // AI feedback per answer { questionId, score, feedback, missed, suggestion }[]
  feedback  Json     @default("[]")

  // Final scorecard after completion
  scorecard Json?

  status    String   @default("in_progress") // "in_progress" | "completed"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([resumeId])
  @@index([status])
  @@index([createdAt])
}

enum SubscriptionPlan {
  FREE
  PRO
}
